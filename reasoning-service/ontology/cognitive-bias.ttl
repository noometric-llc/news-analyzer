@prefix cb: <http://newsanalyzer.org/ontology/cognitive-bias#> .
@prefix na: <http://newsanalyzer.org/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://newsanalyzer.org/ontology/cognitive-bias> .

#################################################################
#    Ontology Declaration
#################################################################

<http://newsanalyzer.org/ontology/cognitive-bias> rdf:type owl:Ontology ;
    owl:imports <http://newsanalyzer.org/ontology> ;
    rdfs:label "Cognitive Bias Ontology"@en ;
    rdfs:comment "Formal OWL taxonomy of cognitive biases and logical fallacies with academic-source grounding. Part of the NewsAnalyzer neuro-symbolic AI evaluation framework."@en ;
    owl:versionInfo "1.0.0" .

#################################################################
#    Classes
#################################################################

###  http://newsanalyzer.org/ontology/cognitive-bias#CognitiveDistortion
cb:CognitiveDistortion rdf:type owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "Cognitive Distortion"@en ;
    rdfs:comment "Abstract root class for cognitive biases and logical fallacies"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#CognitiveBias
cb:CognitiveBias rdf:type owl:Class ;
    rdfs:subClassOf cb:CognitiveDistortion ;
    rdfs:label "Cognitive Bias"@en ;
    rdfs:comment "Systematic deviation from rationality in judgment or decision-making"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#LogicalFallacy
cb:LogicalFallacy rdf:type owl:Class ;
    rdfs:subClassOf cb:CognitiveDistortion ;
    rdfs:label "Logical Fallacy"@en ;
    rdfs:comment "An error in reasoning that renders an argument invalid"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#FormalFallacy
cb:FormalFallacy rdf:type owl:Class ;
    rdfs:subClassOf cb:LogicalFallacy ;
    rdfs:label "Formal Fallacy"@en ;
    rdfs:comment "A fallacy caused by a flaw in the logical structure of an argument"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#InformalFallacy
cb:InformalFallacy rdf:type owl:Class ;
    rdfs:subClassOf cb:LogicalFallacy ;
    rdfs:label "Informal Fallacy"@en ;
    rdfs:comment "A fallacy caused by a flaw in the content or context of an argument rather than its structure"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#DetectionPattern
cb:DetectionPattern rdf:type owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "Detection Pattern"@en ;
    rdfs:comment "A description of how to identify a cognitive distortion in text"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#AcademicSource
cb:AcademicSource rdf:type owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "Academic Source"@en ;
    rdfs:comment "A citable academic publication that defines or studies a cognitive distortion"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#BiasAnnotation
cb:BiasAnnotation rdf:type owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "Bias Annotation"@en ;
    rdfs:comment "An instance of a detected cognitive distortion in text, produced by the bias detector"@en .

#################################################################
#    Object Properties
#################################################################

###  http://newsanalyzer.org/ontology/cognitive-bias#hasAcademicSource
cb:hasAcademicSource rdf:type owl:ObjectProperty ;
    rdfs:domain cb:CognitiveDistortion ;
    rdfs:range cb:AcademicSource ;
    rdfs:label "has academic source"@en ;
    rdfs:comment "Links a cognitive distortion to its citable academic reference"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#hasDetectionPattern
cb:hasDetectionPattern rdf:type owl:ObjectProperty ;
    rdfs:domain cb:CognitiveDistortion ;
    rdfs:range cb:DetectionPattern ;
    rdfs:label "has detection pattern"@en ;
    rdfs:comment "Links a cognitive distortion to its detection criteria"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#relatedTo
cb:relatedTo rdf:type owl:ObjectProperty , owl:SymmetricProperty ;
    rdfs:domain cb:CognitiveDistortion ;
    rdfs:range cb:CognitiveDistortion ;
    rdfs:label "related to"@en ;
    rdfs:comment "Indicates a relationship between two cognitive distortions"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#oppositeOf
cb:oppositeOf rdf:type owl:ObjectProperty , owl:SymmetricProperty ;
    rdfs:domain cb:CognitiveDistortion ;
    rdfs:range cb:CognitiveDistortion ;
    rdfs:label "opposite of"@en ;
    rdfs:comment "Indicates two cognitive distortions are conceptual opposites"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#hasDistortionType
cb:hasDistortionType rdf:type owl:ObjectProperty ;
    rdfs:domain cb:BiasAnnotation ;
    rdfs:range cb:CognitiveDistortion ;
    rdfs:label "has distortion type"@en ;
    rdfs:comment "Links a bias annotation to the type of distortion detected"@en .

#################################################################
#    Datatype Properties
#################################################################

###  http://newsanalyzer.org/ontology/cognitive-bias#hasDefinition
cb:hasDefinition rdf:type owl:DatatypeProperty ;
    rdfs:domain cb:CognitiveDistortion ;
    rdfs:range xsd:string ;
    rdfs:label "has definition"@en ;
    rdfs:comment "The formal definition of a cognitive distortion"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#detectedIn
cb:detectedIn rdf:type owl:DatatypeProperty ;
    rdfs:domain cb:BiasAnnotation ;
    rdfs:range xsd:string ;
    rdfs:label "detected in"@en ;
    rdfs:comment "The text excerpt where a bias was detected"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#hasConfidence
cb:hasConfidence rdf:type owl:DatatypeProperty ;
    rdfs:domain cb:BiasAnnotation ;
    rdfs:range xsd:float ;
    rdfs:label "has confidence"@en ;
    rdfs:comment "Detection confidence score between 0.0 and 1.0"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#hasExplanation
cb:hasExplanation rdf:type owl:DatatypeProperty ;
    rdfs:domain cb:BiasAnnotation ;
    rdfs:range xsd:string ;
    rdfs:label "has explanation"@en ;
    rdfs:comment "Explanation of why the detected text exhibits this distortion"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#sourceAuthor
cb:sourceAuthor rdf:type owl:DatatypeProperty ;
    rdfs:domain cb:AcademicSource ;
    rdfs:range xsd:string ;
    rdfs:label "source author"@en ;
    rdfs:comment "Author(s) of the academic source"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#sourceYear
cb:sourceYear rdf:type owl:DatatypeProperty ;
    rdfs:domain cb:AcademicSource ;
    rdfs:range xsd:integer ;
    rdfs:label "source year"@en ;
    rdfs:comment "Publication year of the academic source"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#sourceTitle
cb:sourceTitle rdf:type owl:DatatypeProperty ;
    rdfs:domain cb:AcademicSource ;
    rdfs:range xsd:string ;
    rdfs:label "source title"@en ;
    rdfs:comment "Title of the academic publication"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#patternDescription
cb:patternDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain cb:DetectionPattern ;
    rdfs:range xsd:string ;
    rdfs:label "pattern description"@en ;
    rdfs:comment "Natural language description of how to detect this distortion in text"@en .

###  http://newsanalyzer.org/ontology/cognitive-bias#patternExample
cb:patternExample rdf:type owl:DatatypeProperty ;
    rdfs:domain cb:DetectionPattern ;
    rdfs:range xsd:string ;
    rdfs:label "pattern example"@en ;
    rdfs:comment "An example of text exhibiting this distortion"@en .

#################################################################
#    Academic Source Individuals
#################################################################

cb:Kahneman2011 rdf:type owl:NamedIndividual , cb:AcademicSource ;
    rdfs:label "Kahneman 2011"@en ;
    rdfs:comment "Foundational work on cognitive biases and dual-process theory"@en ;
    cb:sourceAuthor "Kahneman, D." ;
    cb:sourceYear 2011 ;
    cb:sourceTitle "Thinking, Fast and Slow" .

cb:TverskyKahneman1981 rdf:type owl:NamedIndividual , cb:AcademicSource ;
    rdfs:label "Tversky & Kahneman 1981"@en ;
    rdfs:comment "Seminal paper on framing effects in decision-making"@en ;
    cb:sourceAuthor "Tversky, A. & Kahneman, D." ;
    cb:sourceYear 1981 ;
    cb:sourceTitle "The Framing of Decisions and the Psychology of Choice" .

cb:Nickerson1998 rdf:type owl:NamedIndividual , cb:AcademicSource ;
    rdfs:label "Nickerson 1998"@en ;
    rdfs:comment "Comprehensive review of confirmation bias across domains"@en ;
    cb:sourceAuthor "Nickerson, R. S." ;
    cb:sourceYear 1998 ;
    cb:sourceTitle "Confirmation Bias: A Ubiquitous Phenomenon in Many Guises" .

cb:Walton2008 rdf:type owl:NamedIndividual , cb:AcademicSource ;
    rdfs:label "Walton 2008"@en ;
    rdfs:comment "Standard reference for informal logic and argumentation fallacies"@en ;
    cb:sourceAuthor "Walton, D." ;
    cb:sourceYear 2008 ;
    cb:sourceTitle "Informal Logic: A Pragmatic Approach" .

#################################################################
#    Cognitive Bias Individuals (5)
#################################################################

###  Confirmation Bias
cb:ConfirmationBias rdf:type owl:NamedIndividual , cb:CognitiveBias ;
    rdfs:label "Confirmation Bias"@en ;
    rdfs:comment "Tendency to search for information that confirms pre-existing beliefs"@en ;
    cb:hasDefinition "The tendency to search for, interpret, favor, and recall information in a way that confirms or supports one's prior beliefs or values." ;
    cb:hasAcademicSource cb:Nickerson1998 ;
    cb:hasDetectionPattern cb:ConfirmationBiasPattern ;
    cb:relatedTo cb:AvailabilityHeuristic .

cb:ConfirmationBiasPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Confirmation Bias Detection Pattern"@en ;
    cb:patternDescription "Look for selective evidence citation, dismissal of contradicting evidence, one-sided sourcing, and cherry-picking data that supports a predetermined conclusion." ;
    cb:patternExample "The article cites three studies supporting the policy but ignores five studies showing negative outcomes." .

###  Anchoring Bias
cb:AnchoringBias rdf:type owl:NamedIndividual , cb:CognitiveBias ;
    rdfs:label "Anchoring Bias"@en ;
    rdfs:comment "Tendency to rely too heavily on the first piece of information encountered"@en ;
    cb:hasDefinition "The tendency to rely too heavily on the first piece of information encountered (the anchor) when making decisions, with subsequent judgments being insufficiently adjusted from that anchor." ;
    cb:hasAcademicSource cb:Kahneman2011 ;
    cb:hasDetectionPattern cb:AnchoringBiasPattern ;
    cb:relatedTo cb:FramingEffect .

cb:AnchoringBiasPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Anchoring Bias Detection Pattern"@en ;
    cb:patternDescription "Look for an initial statistic or claim given disproportionate weight, with subsequent information evaluated relative to that anchor rather than on its own merits." ;
    cb:patternExample "The article opens with a $10 billion cost estimate, making the revised $8 billion figure seem like a bargain despite still being enormous." .

###  Framing Effect
cb:FramingEffect rdf:type owl:NamedIndividual , cb:CognitiveBias ;
    rdfs:label "Framing Effect"@en ;
    rdfs:comment "Drawing different conclusions from the same information depending on how it is presented"@en ;
    cb:hasDefinition "Drawing different conclusions from the same information depending on how that information is presented, including through loaded language, selective emphasis, or asymmetric framing of equivalent outcomes." ;
    cb:hasAcademicSource cb:TverskyKahneman1981 ;
    cb:hasDetectionPattern cb:FramingEffectPattern ;
    cb:relatedTo cb:AnchoringBias .

cb:FramingEffectPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Framing Effect Detection Pattern"@en ;
    cb:patternDescription "Look for loaded language, selective emphasis, and asymmetric framing of equivalent outcomes. One side of an issue may be described with positive language while the other uses negative language." ;
    cb:patternExample "The policy is described as 'protecting jobs' rather than 'restricting trade', framing the same action in a positive light." .

###  Availability Heuristic
cb:AvailabilityHeuristic rdf:type owl:NamedIndividual , cb:CognitiveBias ;
    rdfs:label "Availability Heuristic"@en ;
    rdfs:comment "Overestimating the likelihood of events with greater availability in memory"@en ;
    cb:hasDefinition "Overestimating the likelihood of events with greater availability in memory, often because they are recent, vivid, or emotionally charged, leading to distorted risk assessment." ;
    cb:hasAcademicSource cb:Kahneman2011 ;
    cb:hasDetectionPattern cb:AvailabilityHeuristicPattern ;
    cb:relatedTo cb:ConfirmationBias .

cb:AvailabilityHeuristicPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Availability Heuristic Detection Pattern"@en ;
    cb:patternDescription "Look for recent or vivid examples treated as representative of a broader trend, anecdotal evidence used in place of statistics, or emotionally charged cases used to generalize." ;
    cb:patternExample "After reporting on a single plane crash, the article implies flying is dangerous despite statistics showing it is the safest form of travel." .

###  Bandwagon Effect
cb:BandwagonEffect rdf:type owl:NamedIndividual , cb:CognitiveBias ;
    rdfs:label "Bandwagon Effect"@en ;
    rdfs:comment "Tendency to adopt beliefs or behaviors because many others do"@en ;
    cb:hasDefinition "The tendency to adopt beliefs, ideas, or behaviors because many other people hold them, regardless of the underlying evidence." ;
    cb:hasAcademicSource cb:Kahneman2011 ;
    cb:hasDetectionPattern cb:BandwagonEffectPattern .

cb:BandwagonEffectPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Bandwagon Effect Detection Pattern"@en ;
    cb:patternDescription "Look for appeals to popularity such as 'everyone knows', 'most people agree', poll numbers used as argument for correctness, or claims that a position must be right because it is widely held." ;
    cb:patternExample "The article argues the policy must be sound because '78% of Americans support it' without examining the policy's actual merits." .

#################################################################
#    Logical Fallacy Individuals — Informal (6)
#################################################################

###  Ad Hominem
cb:AdHominem rdf:type owl:NamedIndividual , cb:InformalFallacy ;
    rdfs:label "Ad Hominem"@en ;
    rdfs:comment "Attacking the person making the argument rather than the argument itself"@en ;
    cb:hasDefinition "Attacking the person making the argument rather than the argument itself, including personal attacks, character assassination, or questioning motives instead of addressing evidence." ;
    cb:hasAcademicSource cb:Walton2008 ;
    cb:hasDetectionPattern cb:AdHominemPattern .

cb:AdHominemPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Ad Hominem Detection Pattern"@en ;
    cb:patternDescription "Look for personal attacks, character assassination, or questioning motives instead of addressing the substance of the argument." ;
    cb:patternExample "Rather than addressing the senator's healthcare proposal, the article focuses on his past divorce and questions his moral character." .

###  Straw Man
cb:StrawMan rdf:type owl:NamedIndividual , cb:InformalFallacy ;
    rdfs:label "Straw Man"@en ;
    rdfs:comment "Misrepresenting someone's argument to make it easier to attack"@en ;
    cb:hasDefinition "Misrepresenting someone's argument by exaggerating, distorting, or oversimplifying it to make it easier to attack, then refuting the distorted version rather than the original." ;
    cb:hasAcademicSource cb:Walton2008 ;
    cb:hasDetectionPattern cb:StrawManPattern .

cb:StrawManPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Straw Man Detection Pattern"@en ;
    cb:patternDescription "Look for an exaggerated or distorted version of the opponent's position being argued against, rather than what they actually claimed." ;
    cb:patternExample "The opponent said 'we should regulate emissions' but the article characterizes this as 'they want to shut down all factories and destroy the economy'." .

###  False Dilemma
cb:FalseDilemma rdf:type owl:NamedIndividual , cb:InformalFallacy ;
    rdfs:label "False Dilemma"@en ;
    rdfs:comment "Presenting only two options when more exist"@en ;
    cb:hasDefinition "Presenting only two options or alternatives when in reality more possibilities exist, creating an artificial either/or choice that excludes middle ground or additional solutions." ;
    cb:hasAcademicSource cb:Walton2008 ;
    cb:hasDetectionPattern cb:FalseDilemmaPattern .

cb:FalseDilemmaPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "False Dilemma Detection Pattern"@en ;
    cb:patternDescription "Look for either/or framing, 'you're either with us or against us' rhetoric, or arguments that ignore middle ground and additional alternatives." ;
    cb:patternExample "The article states 'we either ban all imports or watch American industry collapse', ignoring tariffs, quotas, and other trade policy options." .

###  Slippery Slope
cb:SlipperySlope rdf:type owl:NamedIndividual , cb:InformalFallacy ;
    rdfs:label "Slippery Slope"@en ;
    rdfs:comment "Asserting that a small first step will inevitably lead to extreme consequences"@en ;
    cb:hasDefinition "Asserting that a small first step will inevitably lead to a chain of related events culminating in extreme consequences, without justifying each link in the causal chain." ;
    cb:hasAcademicSource cb:Walton2008 ;
    cb:hasDetectionPattern cb:SlipperySlopePattern .

cb:SlipperySlopePattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Slippery Slope Detection Pattern"@en ;
    cb:patternDescription "Look for a chain of increasingly extreme consequences claimed to follow from an initial action, without evidence justifying each link in the chain." ;
    cb:patternExample "The article argues that allowing this minor regulation will inevitably lead to government control of all private industry within a decade." .

###  Appeal to Authority
cb:AppealToAuthority rdf:type owl:NamedIndividual , cb:InformalFallacy ;
    rdfs:label "Appeal to Authority"@en ;
    rdfs:comment "Claiming something is true because an authority figure says so, outside their expertise"@en ;
    cb:hasDefinition "Claiming something is true because an authority figure says so, particularly when the authority is cited outside their area of expertise or when the claim is not supported by the relevant evidence." ;
    cb:hasAcademicSource cb:Walton2008 ;
    cb:hasDetectionPattern cb:AppealToAuthorityPattern .

cb:AppealToAuthorityPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Appeal to Authority Detection Pattern"@en ;
    cb:patternDescription "Look for citations of authority figures outside their domain of expertise, or using titles and credentials as evidence rather than substantive arguments." ;
    cb:patternExample "A celebrity physicist is quoted as an authority on economic policy, with their fame lending unearned credibility to the claim." .

###  Red Herring
cb:RedHerring rdf:type owl:NamedIndividual , cb:InformalFallacy ;
    rdfs:label "Red Herring"@en ;
    rdfs:comment "Introducing an irrelevant topic to divert attention from the original issue"@en ;
    cb:hasDefinition "Introducing an irrelevant topic to divert attention from the original issue, thereby avoiding addressing the actual argument or question at hand." ;
    cb:hasAcademicSource cb:Walton2008 ;
    cb:hasDetectionPattern cb:RedHerringPattern .

cb:RedHerringPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Red Herring Detection Pattern"@en ;
    cb:patternDescription "Look for topic shifts, 'what about' deflection, or irrelevant emotional appeals that divert attention from the original argument." ;
    cb:patternExample "When asked about the budget deficit, the politician pivots to talking about immigration, and the article follows the deflection without noting the topic change." .

###  Circular Reasoning
cb:CircularReasoning rdf:type owl:NamedIndividual , cb:InformalFallacy ;
    rdfs:label "Circular Reasoning"@en ;
    rdfs:comment "Using the conclusion as a premise in the argument"@en ;
    cb:hasDefinition "Using the conclusion of an argument as one of its premises, creating a logical loop where the claim is supported only by restating itself in different terms." ;
    cb:hasAcademicSource cb:Walton2008 ;
    cb:hasDetectionPattern cb:CircularReasoningPattern .

cb:CircularReasoningPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Circular Reasoning Detection Pattern"@en ;
    cb:patternDescription "Look for the conclusion being restated as evidence, tautological reasoning, or claims that are supported only by rephrasing the claim itself." ;
    cb:patternExample "The article argues the policy is necessary because it addresses a critical need, where 'critical need' is defined only as 'the need for this policy'." .

#################################################################
#    Logical Fallacy Individuals — Formal (2)
#################################################################

###  Affirming the Consequent
cb:AffirmingTheConsequent rdf:type owl:NamedIndividual , cb:FormalFallacy ;
    rdfs:label "Affirming the Consequent"@en ;
    rdfs:comment "If P then Q; Q is true; therefore P is true (invalid inference)"@en ;
    cb:hasDefinition "A formal logical fallacy of the form: if P then Q; Q is true; therefore P is true. This reverses the direction of a conditional, invalidly assuming the cause from the effect." ;
    cb:hasAcademicSource cb:Walton2008 ;
    cb:hasDetectionPattern cb:AffirmingTheConsequentPattern .

cb:AffirmingTheConsequentPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Affirming the Consequent Detection Pattern"@en ;
    cb:patternDescription "Look for reversed conditional logic where an observed effect is used to conclude a specific cause, ignoring other possible causes for the same effect." ;
    cb:patternExample "The economy improved after the policy was enacted, so the article concludes the policy caused the improvement, ignoring other factors." .

###  Denying the Antecedent
cb:DenyingTheAntecedent rdf:type owl:NamedIndividual , cb:FormalFallacy ;
    rdfs:label "Denying the Antecedent"@en ;
    rdfs:comment "If P then Q; P is false; therefore Q is false (invalid inference)"@en ;
    cb:hasDefinition "A formal logical fallacy of the form: if P then Q; P is false; therefore Q is false. This invalidly assumes that negating the condition negates the result, ignoring other sufficient conditions." ;
    cb:hasAcademicSource cb:Walton2008 ;
    cb:hasDetectionPattern cb:DenyingTheAntecedentPattern .

cb:DenyingTheAntecedentPattern rdf:type owl:NamedIndividual , cb:DetectionPattern ;
    rdfs:label "Denying the Antecedent Detection Pattern"@en ;
    cb:patternDescription "Look for arguments that negate a condition and conclude the result is negated, ignoring that other conditions could produce the same result." ;
    cb:patternExample "The article argues that since the country didn't follow the recommended policy, it cannot possibly achieve economic growth, ignoring alternative paths to growth." .
