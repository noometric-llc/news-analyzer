@prefix cb: <http://newsanalyzer.org/ontology/cognitive-bias#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
#    SHACL Shapes for Cognitive Bias Ontology Validation
#
#    These shapes enforce that:
#    1. Every CognitiveDistortion has a definition, academic source, and detection pattern
#    2. Every BiasAnnotation has a distortion type, text excerpt, and confidence in [0,1]
#    3. Every AcademicSource has an author, year, and title
#################################################################

###  Shape: CognitiveDistortionShape
###  Validates that every cognitive distortion individual has required properties
cb:CognitiveDistortionShape a sh:NodeShape ;
    sh:targetClass cb:CognitiveDistortion ;
    sh:property [
        sh:path cb:hasDefinition ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every cognitive distortion must have at least one definition" ;
    ] ;
    sh:property [
        sh:path cb:hasAcademicSource ;
        sh:minCount 1 ;
        sh:class cb:AcademicSource ;
        sh:message "Every cognitive distortion must have at least one academic source" ;
    ] ;
    sh:property [
        sh:path cb:hasDetectionPattern ;
        sh:minCount 1 ;
        sh:class cb:DetectionPattern ;
        sh:message "Every cognitive distortion must have at least one detection pattern" ;
    ] .

###  Shape: BiasAnnotationShape
###  Validates LLM output annotations conform to expected structure
cb:BiasAnnotationShape a sh:NodeShape ;
    sh:targetClass cb:BiasAnnotation ;
    sh:property [
        sh:path cb:hasDistortionType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class cb:CognitiveDistortion ;
        sh:message "Every bias annotation must have exactly one distortion type" ;
    ] ;
    sh:property [
        sh:path cb:detectedIn ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every bias annotation must have a text excerpt" ;
    ] ;
    sh:property [
        sh:path cb:hasConfidence ;
        sh:minCount 1 ;
        sh:datatype xsd:float ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "Every bias annotation must have a confidence score between 0.0 and 1.0" ;
    ] .

###  Shape: AcademicSourceShape
###  Validates that every academic source has bibliographic metadata
cb:AcademicSourceShape a sh:NodeShape ;
    sh:targetClass cb:AcademicSource ;
    sh:property [
        sh:path cb:sourceAuthor ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every academic source must have at least one author" ;
    ] ;
    sh:property [
        sh:path cb:sourceYear ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "Every academic source must have a publication year" ;
    ] ;
    sh:property [
        sh:path cb:sourceTitle ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every academic source must have a title" ;
    ] .
