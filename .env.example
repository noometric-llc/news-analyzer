# NewsAnalyzer v2 - Production Environment Variables
# Copy this to .env and update with production values
# NEVER commit .env to Git!

# Database
DB_HOST=postgres
DB_NAME=newsanalyzer
DB_USERNAME=newsanalyzer
DB_PASSWORD=changeme_strong_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password_here

# JWT Authentication
JWT_SECRET=changeme_at_least_256_bits_long_secret_key_here

# Domain
DOMAIN=newsanalyzer.org
LETSENCRYPT_EMAIL=admin@newsanalyzer.org

# GitHub Container Registry (for CI/CD)
GITHUB_TOKEN=ghp_your_token_here

# Noometric Intelligence — Reasoning Service
# URL of the external Noometric reasoning service API
# Local dev: clone noometric-intelligence, start the reasoning service, set this to http://localhost:8000
# Production: set to deployed Noometric API URL (see INFRA-2)
REASONING_SERVICE_URL=http://localhost:8000

# For nginx upstream — parsed from REASONING_SERVICE_URL
REASONING_SERVICE_HOST=localhost
REASONING_SERVICE_PORT=8000

# Anthropic API key — passed to the reasoning service for LLM-based analysis
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Noometric API key — used in X-Noometric-API-Key header for reasoning service auth
NOOMETRIC_API_KEY=your-noometric-api-key-here
