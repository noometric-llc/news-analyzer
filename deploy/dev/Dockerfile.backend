# NewsAnalyzer Backend - Local Dev Image
# Full JDK for DevTools hot reload + JMX/VisualVM support
FROM maven:3.9-eclipse-temurin-17

WORKDIR /app

# Copy pom.xml and download dependencies (cached layer)
COPY pom.xml .
RUN mvn dependency:go-offline -B

# Copy Maven wrapper (used by entrypoint)
COPY mvnw .
COPY .mvn .mvn
RUN chmod +x mvnw

# Expose application port and JMX port for VisualVM
EXPOSE 8080 9010

# Source code is volume-mounted at runtime for hot reload
# DevTools will detect classpath changes and trigger restart
# JMX/VisualVM flags are passed via JMX_OPTS env var in docker-compose

# Unset MAVEN_CONFIG from base image - mvnw prepends it to Maven CLI args
ENV MAVEN_CONFIG=

# Shell form so $JMX_OPTS is expanded at runtime, targeting only the Spring Boot JVM
ENTRYPOINT ./mvnw spring-boot:run -Dspring-boot.run.jvmArguments="$JMX_OPTS"
