# NewsAnalyzer Reasoning Service - Local Dev Image
# Python with system deps pre-installed, uvicorn --reload for hot reload
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies (SWI-Prolog for PySwip)
RUN apt-get update && apt-get install -y \
    swi-prolog \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies (cached layer)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Download spaCy model (cached in image layer, ~560MB)
RUN python -m spacy download en_core_web_lg

# Expose service port
EXPOSE 8000

# Source code is volume-mounted at runtime for hot reload
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
